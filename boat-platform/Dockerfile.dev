FROM ubuntu:22.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ninja-build \
    git \
    python3 \
    python3-pip \
    gdb \
    valgrind \
    libacl1-dev \
    && rm -rf /var/lib/apt/lists/*

# CMake ≥3.24 required — Ubuntu 22.04 ships 3.22
RUN set -eux; \
    cmake_version=3.28.3; \
    curl -fsSL "https://github.com/Kitware/CMake/releases/download/v${cmake_version}/cmake-${cmake_version}-linux-x86_64.tar.gz" \
      -o /tmp/cmake.tar.gz; \
    tar xzf /tmp/cmake.tar.gz -C /tmp; \
    ln -sf /tmp/cmake-${cmake_version}-linux-x86_64/bin/cmake /usr/local/bin/cmake; \
    cmake --version

# Rust toolchain — system cargo is too old for some iceoryx2 crate deps
RUN set -eux; \
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
      -o /tmp/rustup-init.sh; \
    sh /tmp/rustup-init.sh -y --default-toolchain stable; \
    "$HOME/.cargo/bin/cargo" --version

ENV PATH="/root/.cargo/bin:${PATH}"

WORKDIR /workspace
CMD ["/bin/bash"]
