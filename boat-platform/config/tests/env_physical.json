{
  "schema_version": "1.0",
  "name": "physical-hil-01",
  "description": "All-physical environment with CAN FD and raw Ethernet.",
  "gateway": {
    "binary": "./build/debug/src/gateway/grpc_gateway/boat_gateway",
    "tick_ms": 10,
    "address": "localhost:50051"
  },
  "buses": {
    "can1": { "type": "physical", "interface": "can0", "bitrate": 500000 },
    "can2": { "type": "physical", "interface": "can1", "bitrate": 500000, "fd": true },
    "eth0": { "type": "raw_eth", "interface": "eth0" }
  },
  "dut": {
    "name": "ecu-42",
    "type": "physical"
  },
  "plugins": [
    { "so_path": "./build/debug/src/plugins/someip/someip.so", "config_json": "{\"sd_port\": 30490}" }
  ]
}
